{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:start": "vinxi dev",
    "dev:e2e": "vite --host 127.0.0.1 --mode e2e",
    "build:spa": "tsc -b && vite build && node ../scripts/prerender-static-pages.mjs",
    "build:start": "vinxi build",
    "build": "vinxi build",
    "start": "vinxi start",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:line": "playwright test --workers=1 --reporter=line --timeout=15000",
    "deploy": "rm -rf dist && npm run build && npm run test:e2e && npx wrangler pages deploy dist --project-name pdftr --branch main",
    "check:prod-bundle": "rm -rf dist && npm run build && ! grep -RIn \"e2e_token\\|e2e_user_email\\|VITE_E2E_AUTH_BYPASS\\|e2e_delay_auth\" dist"
  },
  "dependencies": {
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.16.1",
    "@solidjs/start": "^1.1.13",
    "firebase": "^12.15.0",
    "solid-js": "^1.9.13",
    "vinxi": "^0.5.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-solid": "^2.11.12",
    "wrangler": "^4.105.0"
  }
}
